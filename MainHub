----------------------------------------------------
-- SETTINGS API
----------------------------------------------------

local SettingsManager = {}

SettingsManager.Values = {
	AccentColor = THEME.Accent,
	WindowOpen = false,
	Minimized = false
}

----------------------------------------------------
-- APPLY SETTINGS
----------------------------------------------------

function SettingsManager:Apply()

	ApplyAccent(self.Values.AccentColor)

	if self.Values.Minimized then
		SetMinimized(true)
	else
		SetMinimized(false)
	end

end

----------------------------------------------------
-- EXPORT
----------------------------------------------------

function SettingsManager:Export()

	return {
		AccentColor = self.Values.AccentColor,
		WindowOpen = Open,
		Minimized = Minimized
	}

end

----------------------------------------------------
-- IMPORT
----------------------------------------------------

function SettingsManager:Import(Data)

	if typeof(Data) ~= "table" then
		return
	end

	if Data.AccentColor then
		self.Values.AccentColor = Data.AccentColor
	end

	if Data.Minimized ~= nil then
		self.Values.Minimized = Data.Minimized
	end

	self:Apply()

end

----------------------------------------------------
-- KEEP SETTINGS UPDATED
----------------------------------------------------

local function UpdateSettings()

	SettingsManager.Values.AccentColor = THEME.Accent
	SettingsManager.Values.WindowOpen = Open
	SettingsManager.Values.Minimized = Minimized

end

RunService.RenderStepped:Connect(UpdateSettings)

