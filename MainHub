----------------------------------------------------

function Config:Apply()

	ApplyAccent(self.Data.AccentColor)

	Main.Position = self.Data.WindowPosition
	Main.Size = self.Data.WindowSize

	if self.Data.Minimized then
		SetMinimized(true)
	else
		SetMinimized(false)
	end

	if self.Data.WindowOpen then
		Main.Visible = true
	end

end

----------------------------------------------------
-- EXPORT STRING
----------------------------------------------------

function Config:Export()

	self:Capture()

	local Export = {

		AccentColor = {
			R = math.floor(self.Data.AccentColor.R*255),
			G = math.floor(self.Data.AccentColor.G*255),
			B = math.floor(self.Data.AccentColor.B*255)
		},

		WindowOpen = self.Data.WindowOpen,
		Minimized = self.Data.Minimized

	}

	return HttpService:JSONEncode(Export)

end

----------------------------------------------------
-- IMPORT STRING
----------------------------------------------------

function Config:Import(Json)

	local Success,Data = pcall(function()

		return HttpService:JSONDecode(Json)

	end)

	if not Success then
		return false
	end

	if Data.AccentColor then

		self.Data.AccentColor = Color3.fromRGB(

			Data.AccentColor.R,
			Data.AccentColor.G,
			Data.AccentColor.B

		)

	end

	self.Data.WindowOpen = Data.WindowOpen or false
	self.Data.Minimized = Data.Minimized or false

	self:Apply()

	return true

end

